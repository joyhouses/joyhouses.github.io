---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Carousel from "@/components/Carousel.astro";
import Lightbox from "@/components/Lightbox.astro";
import Youtube from "@/components/Youtube.astro";
import bathroomShower from "@/images/bathroom-shower.webp";
import bathroomToilet from "@/images/bathroom-toilet.webp";
import kitchenFoodWaste from "@/images/kitchen-food-waste.webp";
import kitchenFront from "@/images/kitchen-front.webp";
import kitchenMicrowave from "@/images/kitchen-microwave.webp";
import kitchenRecycling from "@/images/kitchen-recycling.webp";
import kitchenRice from "@/images/kitchen-rice.webp";
import kitchenWaterPurifier from "@/images/kitchen-water-purifier.webp";
import laundryFront from "@/images/laundry-front.webp";
import laundrySupplies from "@/images/laundry-supplies.webp";
import locationMap from "@/images/location-map.webp";
import locationStreet from "@/images/location-street.webp";
import logo from "@/images/logo.svg";
import ogImage from "@/images/og.png";
import roomBed from "@/images/room-bed.webp";
import roomFridge from "@/images/room-fridge.webp";
import roomFront from "@/images/room-front.webp";
import roomTable from "@/images/room-table.webp";
import BaseLayout from "@/layouts/BaseLayout.astro";

type VideoSlide = { video: string; title: string; class?: string };
type ImageSlide = { image: ImageMetadata; alt: string; class?: string };
type Tour = {
  name: string;
  heading: string;
  description: string;
  slides: (VideoSlide | ImageSlide)[];
};

const phone = "010-2122-9717";
const kakao = "https://open.kakao.com/o/soSOePji";

// Youtube video id
const videos = {
  soundproof: "QvBjgaZw-Ps",
  room: "_PHswrKqguc",
  bathroom: "orc0C-cFX3Y",
  kitchen: "LDkVECrvirQ",
  laundry: "m8Sn--T8cQc",
  heating: "g6Aoy6Kls0E",
  location: "hcIgFXeQMLo",
};

const tours: Tour[] = [
  {
    name: "방",
    heading: '"방은 얼마나 넓어요?"',
    description:
      "모든 방에 바깥 창문 있어요.<br />냉장고는 냉동·냉장 분리형이라 남은 음식도 얼려둘 수 있어요.",
    slides: [
      { video: videos.room, title: "방 투어" },
      { image: roomFront, alt: "방 전경" },
      { image: roomBed, alt: "방 침대" },
      { image: roomTable, alt: "방 책상" },
      { image: roomFridge, alt: "열린 냉장고" },
    ],
  },
  {
    name: "화장실",
    heading: '"화장실 깨끗해요?"',
    description: "층마다 2개씩이라 기다릴 일이 적어요.<br />바닥부터 전부 새로 했어요.",
    slides: [
      { video: videos.bathroom, title: "화장실 투어", class: "size-full" },
      { image: bathroomShower, alt: "샤워실" },
      { image: bathroomToilet, alt: "화장실" },
    ],
  },
  {
    name: "주방",
    heading: '"주방 뭐 있어요?"',
    description: "라면, 쌀, 커피, 시리얼 전부 무료예요. <br />따로 사지 않아도 끼니 해결이 돼요.",
    slides: [
      { video: videos.kitchen, title: "주방 투어" },
      { image: kitchenFront, alt: "주방 전경" },
      { image: kitchenRecycling, alt: "주방 분리수거" },
      { image: kitchenWaterPurifier, alt: "CESCO 정수기", class: "aspect-4/3" },
      { image: kitchenMicrowave, alt: "전자레인지" },
      { image: kitchenFoodWaste, alt: "음식물처리기" },
      { image: kitchenRice, alt: "밥솥" },
    ],
  },
  {
    name: "세탁실",
    heading: '"세탁은요?"',
    description: "세탁기 3대, 건조기 3대.<br />세제까지 무료라 빨래 걱정 없어요.",
    slides: [
      { video: videos.laundry, title: "세탁실 투어" },
      { image: laundryFront, alt: "세탁실 전경" },
      { image: laundrySupplies, alt: "세제 · 섬유유연제", class: "aspect-4/3" },
    ],
  },
];

const comparisons = [
  { category: "벽 재질", other: "합판/석고보드", ours: "콘크리트 벽" },
  { category: "창문", other: "내창 포함", ours: "모든 방 외창" },
  { category: "냉난방", other: "중앙냉난방", ours: "개별 냉온풍기" },
  { category: "인터넷", other: "공용 와이파이", ours: "SK 개별 회선" },
  { category: "화장실", other: "층당 1개", ours: "층당 2개" },
  { category: "냉장고", other: "미니 냉장고", ours: "냉동+냉장" },
  { category: "세탁/건조", other: "세탁기만. 건조기 유료", ours: "세탁/건조 전부 무료" },
];

const faqs = [
  {
    label: "입주",
    items: [
      {
        q: "입주 가능일 언제부터인가요?",
        a: "바로 입주할 수 있습니다. 예약 후 1주일 안에 들어오시면 됩니다.",
      },
      {
        q: "방문 상담은 어떻게 하나요?",
        a: "평일 낮 시간에 오시면 됩니다. 미리 문자 주시면 바로 안내해드립니다.",
      },
      { q: "보증금 얼마예요?", a: "5만원입니다." },
      {
        q: "예약 취소하면 환불되나요?",
        a: "들어오기 3일 전까지 취소하시면 보증금 전액 돌려드립니다.",
      },
      {
        q: "중도 퇴실 시 환불되나요?",
        a: "입주 후 2주 안에 나가시면 남은 금액을 돌려드립니다. 2주가 지나면 환불이 어렵습니다. 나가실 때는 1주 전에 알려주세요.",
      },
      { q: "외국인 입주 가능한가요?", a: "가능합니다. 영어, 일본어 안내해드릴 수 있습니다." },
      {
        q: "여성 전용 공간은 어떻게 되어 있나요?",
        a: "디럭스룸이 별도로 있습니다. 자세한 내용은 문의해주세요.",
      },
    ],
  },
  {
    label: "방/시설",
    items: [
      {
        q: "옆방 소리 들리나요?",
        a: "콘크리트 벽이라 일상 생활음(대화, 유튜브 시청 등)은 들리지 않습니다. 다만 큰 소리를 내면 복도를 통해 들릴 수 있습니다.",
      },
      {
        q: "방 크기가 어떻게 되나요?",
        a: "약 2평 내외입니다. 정확한 크기가 궁금하시면 문의해주세요.",
      },
      {
        q: "인터넷 속도 어느 정도예요?",
        a: "SK 인터넷을 새로 깔았습니다. 실측 460Mbps로, 4K 영상 3개를 동시에 틀어도 끊기지 않는 속도입니다.",
      },
      {
        q: "침구류 가져가야 하나요?",
        a: "매트리스커버, 이불, 베개 있습니다. 짐을 최소한으로 줄여서 오셔도 됩니다.",
      },
      {
        q: "취사 가능한가요?",
        a: "1층 공용주방에서 가능합니다. 인덕션, 전자레인지, 밥솥, 정수기, 라면기계, 커피머신까지 갖춰져 있습니다. 방 안에서는 전열기구를 쓸 수 없습니다.",
      },
    ],
  },
  {
    label: "관리비",
    items: [
      {
        q: "관리비 무료에 뭐가 포함돼요?",
        a: "아래 항목 전부 포함입니다. 추가로 내는 돈은 없습니다.",
        chips: [
          { label: "인터넷", price: "3만" },
          { label: "냉난방", price: "5만" },
          { label: "세탁·세제", price: "4만" },
          { label: "쌀·라면", price: "3만" },
          { label: "커피·시리얼", price: "3만" },
          { label: "수도·휴지", price: "2만" },
        ],
      },
    ],
  },
  {
    label: "운영",
    items: [
      { q: "흡연 어디까지 안 되는 거예요?", a: "건물 전체 금연입니다. 흡연실도 없습니다." },
      {
        q: "택배 어떻게 받아요?",
        a: "1층 택배 선반에서 받으시면 됩니다. 외부인은 건물에 들어오지 않습니다.",
      },
      {
        q: "벌레 나오나요?",
        a: "2026년 1월 건물 전체를 리모델링했습니다. 음식점이 없는 건물이라 벌레 걱정이 적습니다.",
      },
      { q: "소음 민원은 어떻게 처리하나요?", a: "관리자에게 편히 연락해주세요." },
    ],
  },
  {
    label: "정부 지원",
    items: [
      {
        q: "청년월세지원 받을 수 있나요?",
        a: "국토부 기준 월 최대 20만 원, 최장 24개월까지 지원받을 수 있습니다. 자격 여부는 복지로에서 확인해보세요.",
      },
      {
        q: "주거급여 받을 수 있나요?",
        a: "소득과 재산 기준을 충족하면 서울 1인 가구 기준 월 최대 34만 원까지 지원받을 수 있습니다. 자격 여부는 복지로에서 확인해보세요.",
      },
    ],
  },
];

const slideClass = "h-full min-w-0 shrink-0 basis-(--slide-size) pl-(--slide-spacing)";
const imageSlideClass = `${slideClass} [&_img]:size-full [&_img]:object-cover [&_img]:rounded-xl`;
---

<BaseLayout
  title="조이하우스 — 2026년 건물 전체 리모델링 · 월 35만원"
  description="신림 고시원. 콘크리트벽 · 전실외창 · 개별냉난방. 서울대벤처타운역 도보 5분"
  ogImage={new URL(ogImage.src, Astro.url.origin).href}
  favicon={logo.src}
  themeColor="#1b2a4a"
>
  <main class="mx-auto max-w-200 pb-20 text-pretty">
    <!-- ==================== 1. HERO ==================== -->
    <section id="hero" class="flex h-[75svh] flex-col items-center justify-center px-5 text-center">
      <h1 class="text-display-sm font-bold whitespace-nowrap">숨길 게 없는 고시원</h1>
      <p class="text-body-lg text-on-surface-variant mt-4 whitespace-nowrap">
        2026년 1월, 건물 전체를 새로 리모델링했어요.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        {
          ["콘크리트벽", "전실외창", "개별냉난방", "개별인터넷", "월 35만원"].map((chip) => (
            <span class="text-body-sm text-on-surface-variant bg-surface-container rounded-full px-3 py-1">
              {chip}
            </span>
          ))
        }
      </div>
    </section>

    <!-- ==================== 2. 방음 (임팩트) ==================== -->
    <section data-section="방음" class="px-5 py-24 text-center">
      <h2 class="text-headline-lg mb-12 font-bold">벽, 진짜 콘크리트예요</h2>
      <div class="fade-in mx-auto mb-8 max-w-80 overflow-hidden rounded-xl">
        <iframe
          src={`https://www.youtube.com/embed/${videos.soundproof}?rel=0&playsinline=1`}
          title="방음 테스트"
          loading="lazy"
          class="aspect-9/16 w-full"
        >
        </iframe>
      </div>
      <p class="fade-in text-body-lg">옆방 기침 소리까지 공유할 필요 없으니까요.</p>
    </section>

    <!-- ==================== 3. 공간 투어 (정보) ==================== -->
    <section class="px-5 py-16">
      {
        tours.map((section) => (
          <div class="py-12" data-section={section.name}>
            <h3 class="fade-in text-headline-md mb-6 font-bold">{section.heading}</h3>
            <div class="fade-in">
              <Carousel style="--slide-size: 85%; --slide-spacing: 0.75rem">
                <div data-slot="carousel-viewport" class="-mx-4 overflow-hidden rounded-xl">
                  <div class="-ml-(--slide-spacing) flex h-[65svh] [touch-action:pan-y_pinch-zoom] sm:h-[min(80cqi,480px)]">
                    {section.slides.map((slide) =>
                      "video" in slide ? (
                        <div class={slideClass}>
                          <div class="bg-scrim flex size-full items-center overflow-hidden rounded-xl">
                            <Youtube
                              videoid={slide.video}
                              params="mute=1"
                              class={slide.class ?? "w-full"}
                            />
                          </div>
                        </div>
                      ) : (
                        <div class={imageSlideClass}>
                          <Image
                            src={slide.image}
                            alt={slide.alt}
                            class={slide.class}
                            widths={[320, 540, 800]}
                            sizes="(min-width: 800px) 680px, 85vw"
                            data-lightbox
                          />
                        </div>
                      ),
                    )}
                  </div>
                </div>
              </Carousel>
            </div>
            <p
              class="fade-in text-body-md text-on-surface-variant mt-4"
              set:html={section.description}
            />
          </div>
        ))
      }
    </section>

    <!-- ==================== 4. 냉난방 (임팩트) ==================== -->
    <section data-section="냉난방" class="px-5 py-24 text-center">
      <h2 class="fade-in text-headline-lg mb-12 font-bold">
        여름엔 시원하고,
        <br class="sm:hidden" />
        겨울엔 따뜻한가요?
      </h2>
      <div class="fade-in mx-auto mb-8 max-w-80 overflow-hidden rounded-xl">
        <Youtube videoid={videos.heating} class="aspect-9/16 w-full" />
      </div>
      <p class="fade-in text-body-lg font-semibold">
        방마다 냉온풍기 따로 있어요.
        <br />
        내가 원하는 온도로 직접 맞출 수 있어요.
      </p>
    </section>

    <!-- ==================== 5. 비교표 (정보) ==================== -->
    <section data-section="비교표" class="px-5 py-16">
      <h2 class="fade-in text-headline-md mb-8 font-bold">같은 35만원, 이만큼 다릅니다.</h2>
      <div class="fade-in -mx-4">
        <div class="mb-1 flex justify-between px-4">
          <p class="text-label-md text-on-surface-variant py-3">일반 고시원</p>
          <p class="text-label-md text-primary py-3 font-semibold">조이하우스</p>
        </div>
        <div class="flex flex-col gap-2">
          {
            comparisons.map((item) => (
              <div class="bg-surface-container-lowest text-on-surface-variant rounded-md px-4 py-4">
                <p class="text-label-md mb-2 font-semibold">{item.category}</p>
                <div class="flex justify-between">
                  <span class="text-body-md">{item.other}</span>
                  <span class="text-body-md text-primary font-bold">{item.ours}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
      <p class="fade-in text-body-lg mt-8 font-bold">월 35만원. 관리비 0원</p>
      <p class="fade-in text-body-lg text-primary font-bold">
        청년월세지원 받으면 실질 월 15만원이에요.
      </p>
      <p class="fade-in text-body-md text-on-surface-variant mt-1">
        비슷한 조건의 원룸은 보증금 포함 월 55~90만원이에요.
      </p>
    </section>

    <!-- ==================== 6. 위치 (정보) ==================== -->
    <section data-section="위치" class="px-5 py-16">
      <h2 class="fade-in text-headline-md mb-8 font-bold">역까지 진짜 5분?</h2>
      <div class="fade-in mb-4 overflow-hidden rounded-xl">
        <Youtube videoid={videos.location} class="w-full" />
      </div>
      <p class="fade-in text-body-md mb-10">
        서울대벤처타운역까지 도보 5분이에요.
        <br />
        걸어오는 길도 편해요.
      </p>
      <Image
        src={locationMap}
        alt="위치 지도"
        widths={[320, 540, 800]}
        sizes="(min-width: 800px) 760px, calc(100vw - 40px)"
        data-lightbox
        class="fade-in mb-4 w-full rounded-xl"
      />
      <p class="fade-in text-body-md mb-10">
        녹두거리 바로 앞이에요.
        <br />
        편의점, 마트, 식당 모두 1분 거리예요.
      </p>
      <Image
        src={locationStreet}
        alt="야간 거리 전경"
        widths={[320, 540, 800]}
        sizes="(min-width: 800px) 760px, calc(100vw - 40px)"
        data-lightbox
        class="fade-in mb-4 w-full rounded-xl"
      />
      <p class="fade-in text-body-md">
        큰 도로에서 한 블록 안쪽이라
        <br />
        새벽에도 조용해요.
      </p>
    </section>

    <!-- ==================== 7. 운영 원칙 (임팩트) ==================== -->
    <section data-section="운영원칙" class="px-5 py-24">
      <h2 class="fade-in text-headline-md mb-12 font-bold">이런 기준으로 운영하고 있어요</h2>
      <ul class="text-body-lg space-y-4">
        {
          [
            "남성 여성 층이 분리되어 있어요.",
            "외부인은 건물에 들어올 수 없어요.",
            "건물 전체 금연이에요. 흡연실도 없어요.",
            "현관, 각 방 모두 전자도어락이에요.",
            "방에 신발장을 두어 분실 걱정 없어요.",
          ].map((rule) => (
            <li class="fade-in flex items-start gap-3">
              <span class="bg-primary mt-2 size-1.5 shrink-0 rounded-full" />
              <span>{rule}</span>
            </li>
          ))
        }
      </ul>
      <p class="fade-in text-body-md text-on-surface-variant mt-12">
        리모델링 과정이 궁금하시면
        <a
          href="https://blog.naver.com/joyhouse_snu"
          target="_blank"
          rel="noopener"
          class="text-primary font-medium underline"
          data-link
        >
          블로그에서
        </a>
        확인해보세요.
      </p>
    </section>

    <!-- ==================== 8. FAQ (정보) ==================== -->
    <section data-section="FAQ" class="px-5 py-16">
      <h2 class="text-headline-md mb-8 font-bold">자주 묻는 질문</h2>
      {
        faqs.map((section) => (
          <div class="mt-12">
            <p class="text-label-md text-on-surface-variant mb-4">{section.label}</p>
            {section.items.map((item) => (
              <div class="border-outline-variant border-t last:border-b">
                <button
                  data-faq
                  type="button"
                  aria-expanded="false"
                  class="text-body-lg flex w-full cursor-pointer items-center justify-between py-4 font-medium"
                >
                  <span>{item.q}</span>
                  <span class="text-outline ml-4 shrink-0 transition-[rotate] duration-200 data-open:rotate-90">
                    &#9656;
                  </span>
                </button>
                <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-150 ease-out data-open:grid-rows-[1fr]">
                  <div class="text-body-md text-on-surface-variant overflow-hidden">
                    <div class="max-w-150 pb-4">
                      {item.a}
                      {"chips" in item && (
                        <div class="mt-3 grid grid-cols-2 gap-2 sm:grid-cols-3">
                          {item.chips.map((chip) => (
                            <span class="text-body-sm bg-surface-container-lowest flex items-center justify-between rounded-lg px-3 py-2">
                              <span>{chip.label}</span>
                              <span class="text-on-surface">{chip.price}</span>
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ))
      }
    </section>

    <!-- ==================== 9. 하단 안내 + 푸터 ==================== -->
    <section
      id="contact"
      data-section="하단안내"
      class="text-on-surface-variant px-5 py-20 text-center"
    >
      <p class="text-title-md">궁금한게 있으면 편히 물어보세요.</p>
      <p class="text-body-md mt-2">조이하우스 · 서울 관악구 대학4길 40 · {phone}</p>
    </section>
    <footer class="text-body-sm text-outline px-5 py-8 text-center">© 조이하우스</footer>
  </main>

  <!-- ==================== STICKY CTA ==================== -->
  <div
    id="sticky-cta"
    class="bg-surface fixed right-0 bottom-0 left-0 z-50 translate-y-full shadow-md transition-[translate] duration-250 data-show:translate-y-0"
  >
    <div class="mx-auto max-w-200 px-4 py-3">
      <div class="flex gap-2">
        <a
          href={kakao}
          target="_blank"
          rel="noopener"
          data-label="카카오톡"
          class="border-primary text-primary text-label-lg flex min-h-12 flex-1 items-center justify-center rounded-lg border text-center font-bold"
        >
          카톡 문의
        </a>
        <a
          href={`tel:${phone}`}
          data-label="전화"
          class="bg-primary text-on-primary text-label-lg flex min-h-12 flex-1 items-center justify-center rounded-lg text-center font-bold"
        >
          전화 문의
        </a>
      </div>
      <p class="text-body-sm text-on-surface-variant mt-1.5 text-center">
        상담 8:00-21:00 · 문자는 언제든 편하게
      </p>
    </div>
  </div>

  <Lightbox />

  <!-- Scroll fade-in 폴백 -->
  <script>
    if (!CSS.supports("animation-timeline", "view()")) {
      const fadeObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) entry.target.classList.add("visible");
          }
        },
        { threshold: 0.1 },
      );
      for (const element of document.querySelectorAll(".fade-in")) {
        fadeObserver.observe(element);
      }
    }
  </script>

  <!-- Sticky CTA -->
  <script>
    const hero = document.getElementById("hero");
    const sticky = document.getElementById("sticky-cta");
    if (hero && sticky) {
      new IntersectionObserver(
        ([entry]) => sticky.toggleAttribute("data-show", !entry.isIntersecting),
        { threshold: 0 },
      ).observe(hero);
    }
  </script>

  <!-- FAQ 아코디언 -->
  <script>
    for (const button of document.querySelectorAll<HTMLButtonElement>("[data-faq]")) {
      const panel = button.nextElementSibling as HTMLElement | null;
      const arrow = button.querySelector(":scope > :last-child") as HTMLElement | null;

      button.addEventListener("click", () => {
        const open = panel?.toggleAttribute("data-open");
        arrow?.toggleAttribute("data-open");
        button.setAttribute("aria-expanded", String(!!open));
      });
    }
  </script>

  <!-- GA4 Custom Events -->
  <script>
    const track = (name: string, label: string) => {
      (window as any).gtag?.("event", name, { label, property: "joyhouse" });
    };

    // CTA
    for (const element of document.querySelectorAll<HTMLAnchorElement>(
      "#sticky-cta a[data-label]",
    )) {
      element.addEventListener("click", (e) => {
        const label = element.dataset.label!;
        e.preventDefault();
        track("tap_contact", label);
        setTimeout(() => {
          if (element.target === "_blank") window.open(element.href, "_blank", "noopener");
          else location.href = element.href;
        }, 150);
      });
    }

    // FAQ (항목당 1회)
    const openedFaqs = new Set<string>();
    for (const button of document.querySelectorAll<HTMLButtonElement>("[data-faq]")) {
      button.addEventListener("click", () => {
        const label = button.querySelector("span")?.textContent?.trim() ?? "unknown";
        if (!openedFaqs.has(label)) {
          openedFaqs.add(label);
          track("open_faq", label);
        }
      });
    }

    // 블로그
    document.querySelector<HTMLElement>("[data-link]")?.addEventListener("click", () => {
      track("tap_link", "네이버 블로그");
    });

    // 콘텐츠 탐색 (섹션당 1회)
    const exploredSections = new Set<string>();
    for (const section of document.querySelectorAll<HTMLElement>("[data-section]")) {
      const name = section.dataset.section!;
      const trackOnce = () => {
        if (exploredSections.has(name)) return;
        exploredSections.add(name);
        track("explore_section", name);
      };
      section
        .querySelector('[data-slot="carousel"]')
        ?.addEventListener("carousel:navigate", trackOnce);
      section.addEventListener("lightbox:navigate", trackOnce);
    }

    // 섹션 도달 (지정 섹션만)
    const trackedSections = new Set(["비교표", "FAQ"]);
    const sectionObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            track("view_section", (entry.target as HTMLElement).dataset.section ?? "unknown");
            sectionObserver.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.3 },
    );
    for (const element of document.querySelectorAll<HTMLElement>("[data-section]")) {
      if (trackedSections.has(element.dataset.section!)) {
        sectionObserver.observe(element);
      }
    }
  </script>

  <style is:global>
    :root {
      --color-primary: #1b2a4a;
    }
  </style>
</BaseLayout>
